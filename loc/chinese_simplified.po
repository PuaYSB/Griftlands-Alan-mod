#. BATTLE_FEATURE.SPARK_RESERVE.NAME
msgctxt "BATTLE_FEATURE.SPARK_RESERVE.NAME"
msgid ""
msgstr "火花储备"

#. BATTLE_FEATURE.SPARK_RESERVE.DESC
msgctxt "BATTLE_FEATURE.SPARK_RESERVE.DESC"
msgid ""
msgstr "至多拥有10层，当拥有10层火花储备时便立即使层数清零并使承受体力上限25%的伤害。"

#. BATTLE_FEATURE.LUMIN_RESERVE.NAME
msgctxt "BATTLE_FEATURE.LUMIN_RESERVE.NAME"
msgid ""
msgstr "蓝明储备"

#. BATTLE_FEATURE.LUMIN_RESERVE.DESC
msgctxt "BATTLE_FEATURE.LUMIN_RESERVE.DESC"
msgid ""
msgstr "你的下一次攻击会对目标施加<#HILITE>{1}</>{lumin_burnt}和<#HILITE>{2}</>{DEFEND}。\n后者每5层就使数值加1。"

#. BATTLE_FEATURE.PC_ALAN_WEIGHTED.NAME
msgctxt "BATTLE_FEATURE.PC_ALAN_WEIGHTED.NAME"
msgid ""
msgstr "重量 "

#. BATTLE_FEATURE.PC_ALAN_WEIGHTED.DESC
msgctxt "BATTLE_FEATURE.PC_ALAN_WEIGHTED.DESC"
msgid ""
msgstr "在该牌使用前如果所有手牌花费总和<#HILITE>大于等于</>一定数则会获得额外效果。"

#. BATTLE_FEATURE.PC_ALAN_LIGHTWEIGHT.NAME
msgctxt "BATTLE_FEATURE.PC_ALAN_LIGHTWEIGHT.NAME"
msgid ""
