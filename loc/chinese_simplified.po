msgctxt "BATTLE_FEATURE.PA_HAULING_CARGO.NAME"
msgid ""
msgstr "搬运货物"

#. BATTLE_FEATURE.PA_HAULING_CARGO.DESC
msgctxt "BATTLE_FEATURE.PA_HAULING_CARGO.DESC"
msgid ""
msgstr "每当打出费用至少为2的牌时获得<#HILITE>{1}</>{DEFEND}。"

